VESTI_API_BASE_URL=https://integracao.meuvesti.com/api
VESTI_API_TOKEN=
VESTI_COMPANY_ID=
VESTI_API_TOKEN_HEADER_NAME=apikey

UPZERO_API_BASE_URL=https://api.upzero.com.br
UPZERO_API_TOKEN=
UPZERO_API_TOKEN_HEADER_NAME=X-API-KEY

# Cloud Run Jobs (opcional - so necessario se NEXT_PUBLIC_USE_CLOUD_RUN_JOBS=true)
# Dispara a migracao/sincronizacao como um Cloud Run Job em vez de manter a
# requisicao HTTP do painel aberta. Ver DEPLOY_LONG_RUNNING.md.
GOOGLE_CLOUD_PROJECT=
CLOUD_RUN_JOB_REGION=
CLOUD_RUN_CATALOG_JOB_NAME=
CLOUD_RUN_COLOR_TERMS_JOB_NAME=
NEXT_PUBLIC_USE_CLOUD_RUN_JOBS=false
